# Copy to `.env` and adjust. `.env` is gitignored.

# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Database (SQLite file path, relative to the server/ directory)
DATABASE_URL=./data/paperqueue.db

# --- Zotero authentication ---
# The app signs in with a PERSONAL API KEY (created at
# https://www.zotero.org/settings/keys/new). Nothing to configure here for that
# flow — the key is entered in the app and stored in the database.
#
# The OAuth 1.0a flow is also implemented as an alternative. Only fill these in
# if you want the "Connect Zotero" web flow instead of pasting a key; register
# an app at https://www.zotero.org/oauth/apps to get them.
ZOTERO_CLIENT_KEY=
ZOTERO_CLIENT_SECRET=
