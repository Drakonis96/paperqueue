# Copy to `.env` and fill in your key. `.env` is gitignored.
#
# The ONLY thing you really need is a Zotero Web API key. Create one at
# https://www.zotero.org/settings/keys/new with library *read & write* access.
# Leave it blank to explore a built-in demo library first.

ZOTERO_API_KEY=

# Port the single service listens on (host and container). Default 5954.
PORT=5954

# --- Optional ---------------------------------------------------------------

# Normally left blank — the user id is resolved from the key automatically.
# Set this to read a group library instead, e.g. ZOTERO_LIBRARY=groups/123456
# ZOTERO_LIBRARY=

# Force the demo library even when a key is set (handy for screenshots).
# DEMO_MODE=0

# Where server-side user settings are stored (daily goal, queues, AI favourites).
# In Docker this defaults to /data (mount a volume there); for a bare Node run it
# defaults to web/data. Override only if you want a different path.
# DATA_DIR=/data

# --- Optional basic auth ----------------------------------------------------
# DISABLED by default — out of the box PaperQueue asks for no credentials.
# Set AUTH_ENABLED=1 to require a single shared username/password (a session
# cookie is issued on success). The defaults below are admin / paperqueue — set
# your own. Login attempts are rate-limited per IP to deter brute force.
# AUTH_ENABLED=1
# AUTH_USERNAME=admin
# AUTH_PASSWORD=paperqueue
# AUTH_MAX_ATTEMPTS=5        # failed tries allowed within the window
# AUTH_WINDOW_MINUTES=15     # the counting window
# AUTH_BLOCK_MINUTES=15      # lockout duration once the limit is hit
# AUTH_SESSION_HOURS=720     # how long a login stays valid (default 30 days)
# AUTH_COOKIE_SECURE=1       # set when serving over HTTPS

# --- Security headers -------------------------------------------------------
# Hardening response headers (CSP, X-Content-Type-Options, X-Frame-Options…) are
# added to every response by default. Recommended if you expose PaperQueue beyond
# a trusted network. Set to 0 only if a reverse proxy already adds them.
# PQ_SECURITY_HEADERS=1
# Who may embed the app in an <iframe>. Default 'none' blocks all framing
# (clickjacking). To embed it in a self-hosted dashboard (Heimdall, Organizr,
# Homepage…) set this to 'self' or a space-separated list of allowed origins.
# PQ_FRAME_ANCESTORS='none'

# --- AI assistant (optional) ------------------------------------------------
# Add a key for any provider to enable the in-app AI chat (suggest papers for
# your queue, reorder it). Keys stay on the SERVER — they're never sent to the
# browser and never logged. Leave all blank to keep the assistant disabled.
#
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# DEEPSEEK_API_KEY=sk-...
#
# Google Gemini (https://aistudio.google.com/apikey) — uses Gemini's
# OpenAI-compatible endpoint. GOOGLE_API_KEY works as an alias.
# GEMINI_API_KEY=...
#
# Any OpenAI-compatible endpoint (Ollama, Groq, LM Studio, vLLM…):
# AI_CUSTOM_NAME=Ollama
# AI_CUSTOM_BASE_URL=http://localhost:11434/v1
# AI_CUSTOM_API_KEY=ollama
