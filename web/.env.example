# Copy to `.env` and fill in your key. `.env` is gitignored.
#
# The ONLY thing you really need is a Zotero Web API key. Create one at
# https://www.zotero.org/settings/keys/new with library *read & write* access.
# Leave it blank to explore a built-in demo library first.

ZOTERO_API_KEY=

# Port the single service listens on (host and container). Default 5954.
PORT=5954

# --- Optional ---------------------------------------------------------------

# Normally left blank — the user id is resolved from the key automatically.
# Set this to read a group library instead, e.g. ZOTERO_LIBRARY=groups/123456
# ZOTERO_LIBRARY=

# Force the demo library even when a key is set (handy for screenshots).
# DEMO_MODE=0

# --- AI assistant (optional) ------------------------------------------------
# Add a key for any provider to enable the in-app AI chat (suggest papers for
# your queue, reorder it). Keys stay on the SERVER — they're never sent to the
# browser and never logged. Leave all blank to keep the assistant disabled.
#
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# DEEPSEEK_API_KEY=sk-...
#
# Any OpenAI-compatible endpoint (Ollama, Groq, LM Studio, vLLM…):
# AI_CUSTOM_NAME=Ollama
# AI_CUSTOM_BASE_URL=http://localhost:11434/v1
# AI_CUSTOM_API_KEY=ollama
